{
  "name": "agentbranch",
  "version": "3.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "demo",
    "contracts"
  ],
  "overrides": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "test:backend": "npm run test --workspace=backend",
    "test:frontend": "npm run test --workspace=frontend",
    "test": "npm run test:backend && npm run test:frontend",
    "demo": "npm run demo --workspace=demo",
    "seed": "npm run seed --workspace=demo",
    "migrate": "npm run migrate --workspace=backend",
    "migrate:v2": "npm run migrate:v2 --workspace=backend",
    "migrate:v3": "npm run migrate:v3 --workspace=backend",
    "smoke": "bash scripts/smoke.sh",
    "test:e2e": "bash scripts/e2e.sh",
    "install:all": "npm install",
    "forge:build": "cd contracts && forge build",
    "forge:test": "cd contracts && forge test",
    "forge:deploy": "cd contracts && forge script script/Deploy.s.sol --rpc-url $SEPOLIA_RPC_URL --broadcast"
  }
}
