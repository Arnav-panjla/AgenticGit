# ═══════════════════════════════════════════════════════════════════════════════
# AgentBranch Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Requires: uuid-ossp extension (for UUIDs), pgvector extension (for embeddings)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentbranch

# ─── Backend Server ────────────────────────────────────────────────────────────
PORT=3001

# ─── Authentication ────────────────────────────────────────────────────────────
# JWT secret for signing tokens (use a strong random string in production)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT expiration time (e.g., "7d", "24h", "1h")
JWT_EXPIRES_IN=7d

# ─── Fileverse (Content Storage) ───────────────────────────────────────────────
# Set to "true" for demo mode (in-memory storage, no real Fileverse API)
FILEVERSE_DEMO=true

# Required only if FILEVERSE_DEMO=false
FILEVERSE_API_KEY=

# ─── OpenAI (Embeddings + Judge) ───────────────────────────────────────────────
# Required for semantic commit search and AutoResearch judge
# Get your key at: https://platform.openai.com/api-keys
# If not set, embeddings will be skipped and judge will use mock scoring
OPENAI_API_KEY=

# Model configuration (defaults shown)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_JUDGE_MODEL=gpt-4o

# ─── Blockchain (Sepolia Testnet) ──────────────────────────────────────────────
# Sepolia RPC URL (Infura or Alchemy)
# Infura: https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SEPOLIA_RPC_URL=

# AgentBranchToken (ABT) contract address
# Set this after running: forge script script/Deploy.s.sol --rpc-url $SEPOLIA_RPC_URL --broadcast
ABT_CONTRACT_ADDRESS=

# Required deposit amount for new agent registration (in ABT, 18 decimals)
AGENT_DEPOSIT_AMOUNT=50

# Private key for backend to verify transactions (optional, for advanced features)
# NEVER commit this key; use a dedicated testnet wallet
BACKEND_PRIVATE_KEY=

# ─── Frontend ──────────────────────────────────────────────────────────────────
# API URL for frontend to reach backend
VITE_API_URL=http://localhost:3001

# WalletConnect project ID for MetaMask integration
# Get one at: https://cloud.walletconnect.com/
VITE_WALLET_CONNECT_PROJECT_ID=

# Chain ID for blockchain interactions (11155111 = Sepolia)
VITE_CHAIN_ID=11155111

# ABT contract address (same as backend, exposed to frontend)
VITE_ABT_CONTRACT_ADDRESS=
